# 复制到 .env 并填值。生产环境用 `fly secrets set` 而不是此文件。

# SQLite / app.log / clips 根目录。本地留空用项目根；Fly 设 /app/data。
DATA_DIR=./data

# B站 cookies 加密密钥。稳定、不要换；生成：python -c "import secrets; print(secrets.token_urlsafe(32))"
COOKIE_SECRET=change-me-to-a-long-random-string-abcdef1234567890

# 首次启动 users 表空时 upsert 管理员；留空则不创建。
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# 智谱 BigModel API Key（AI 机器人用）。https://open.bigmodel.cn/usercenter/apikeys
BIGMODEL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxx

# Resend API Key（注册验证码邮件用）。https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
# 发件地址（必须是 Resend 已验证的域名）
RESEND_FROM=狗狗机器人 <noreply@blackbubu.us>

# Cloudflare Turnstile（人机校验，防注册/重置滥用）。https://dash.cloudflare.com/?to=/:account/turnstile
# 两者都留空 → 跳过校验（本地开发用）
TURNSTILE_SITE_KEY=0xAAAAAAAAAAAAAAAAAAAAAA
TURNSTILE_SECRET=0xAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# 爱发电（ifdian）开发者凭据。https://ifdian.net/dashboard/dev
# Webhook 收到推送后会用这两个反查 query-order 验真。两者留空则 webhook 拒绝处理。
AFDIAN_USER_ID=
AFDIAN_TOKEN=

# 微信推送告警（异常重启 + 内存超阈值）。https://sct.ftqq.com/
# 留空则告警静默。
SERVERCHAN_KEY=

# 支付宝当面付（用户自助扫码续费房间）。https://open.alipay.com
#   APP_ID         : 应用顶部 16 位数字
#   APP_PRIVATE_KEY: 密钥工具生成的"应用私钥2048.txt"内容（PKCS#1/PKCS#8 都吃）
#   PUBLIC_KEY     : 上传应用公钥后页面回显的"支付宝公钥"（不是你上传的那个！）
# 三个都有才开启支付宝续费按钮，缺任一前端 disabled。
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
